# ========================================================
# AL-RAFIDAIN AGI - MASTER CONFIGURATION FILE
# ========================================================
# تعليمات للعملاء: لا تقم بمشاركة هذا الملف مع أي جهة.
# هذا الملف يحتوي على المفاتيح السرية للذكاء الاصطناعي السيادي الخاص بك.

# 1. مفتاح عقل المايسترو (Gemini 1.5 Pro)
GOOGLE_API_KEY="ضع_المفتاح_هنا"

# 2. مفتاح روبوت التليجرام الخاص بالمراقبة
TELEGRAM_API_TOKEN="ضع_توكن_البوت_هنا"

# 3. عنوان الاتصال بماكينات المصنع (PLC Control IP)
PLC_MASTER_IP="192.168.0.5"

# 4. بيئة العمل (إنتاج أم تطوير)
ENVIRONMENT="PRODUCTION"
