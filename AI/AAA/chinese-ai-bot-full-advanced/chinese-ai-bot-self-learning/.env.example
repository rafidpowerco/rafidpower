# لا ترفع ملف .env الحقيقي أو أي ملف فيه مفاتيح/كلمات مرور إلى GitHub.
# احتفظ بالأسرار على الخادم أو في مدير أسرار؛ استخدم هذا الملف كقالب فقط (.env.example).

# --- نموذجك الخاص (خادم OpenAI-compatible: Ollama / vLLM / LM Studio / خادمك بعد الضبط) ---
# LLM_BACKEND=custom
# CUSTOM_LLM_BASE_URL=http://127.0.0.1:11434/v1
# CUSTOM_LLM_MODEL=mistral:latest
# CUSTOM_LLM_API_KEY=
# CUSTOM_LLM_MAX_TOKENS=8192

# --- OpenRouter (مجاني ضمن حدودهم) ---
# LLM_BACKEND=openrouter
# OPENROUTER_API_KEY=sk-or-v1-...
# OPENROUTER_LLM_MODEL=openrouter/free

# --- Forge (الافتراضي في المشروع) ---
# LLM_BACKEND=forge
# BUILT_IN_FORGE_API_KEY=

# عند فشل Forge، جرّب OpenRouter إن وُجد المفتاح (عطّل بـ LLM_FALLBACK_OPENROUTER=0)
# LLM_FALLBACK_OPENROUTER=1

# إعادة محاولة تلقائية لطلبات LLM عند 429/502/503/504 أو خطأ شبكة (0 = بدون إعادة)
# LLM_FETCH_MAX_RETRIES=2
# LLM_FETCH_RETRY_BASE_MS=750

# Ollama في الكتالوج فقط — اكتشاف تلقائي (عطّل بـ OLLAMA_AUTO_PROBE=0)
# OLLAMA_BASE_URL=http://127.0.0.1:11434

# حد طلبات /api/trpc في الدقيقة (0 = تعطيل)
# API_RATE_LIMIT_PER_MINUTE=120
# عند الضبط: مسارات bot التراثية تتطلب الرأس x-internal-bot-secret بنفس القيمة (يُنصح في الإنتاج)
# INTERNAL_BOT_API_SECRET=ضع_سلسلة_عشوائية_طويلة

# --- Docker (docker compose up --build) ---
# DATABASE_URL=mysql://root:root@mysql:3306/botdb
# حجم بركة اتصالات MySQL (اختياري)
# DB_POOL_SIZE=12
# DB_POOL_MAX_IDLE=6
# مع ملف docker-compose: استخدم --profile ollama لخدمة Ollama ثم CUSTOM_LLM_BASE_URL=http://ollama:11434/v1
# ترحيل تلقائي عند إقلاع الحاوية (Docker يضبطه افتراضياً): RUN_MIGRATIONS_ON_START=1
# إن فشل اكتشاف مجلد drizzle/ (cwd غير جذر المشروع): مسار مطلق
# DRIZZLE_MIGRATIONS_FOLDER=/app/drizzle

# --- تشخيص من الطرفية ---
# pnpm run verify:llm

# --- مرحلة 1–2: مستأجر افتراضي + عزل بيانات في DB ---
# DEFAULT_TENANT_ID=default
# للواجهة (Vite) — يُرسل مع طلبات bot.* إن وُجد
# VITE_DEFAULT_TENANT_ID=default

# شريط «إصدار تجريبي» أعلى كل الصفحات (يُضبط عند pnpm build أو pnpm dev)
# انظر docs/BETA_LAUNCH_AR.md
# VITE_SHOW_BETA_BANNER=1

# تحليلات Umami اختيارية (يُحقن السكربت من main.tsx فقط عند تعيين الاثنين)
# VITE_ANALYTICS_ENDPOINT=https://analytics.example.com
# VITE_ANALYTICS_WEBSITE_ID=your-uuid

# بوابة خفيفة «لا ضرر» مفعّلة افتراضياً — عطّل للاختبار المحلي فقط: NO_HARM_GATE=0

# تعلّم مجمّع لكل مستأجر (جدول collective_pattern_stats) — عطّل بـ 0
# COLLECTIVE_LEARNING=1
# مجلس نماذج: عدد مرات استدعاء LLM بالتسلسل (1 = معطّل). يحتاج OPENROUTER أو custom + مفاتيح
# LLM_COUNCIL_ROUNDS=1
# LLM_COUNCIL_MODELS=openrouter/auto,meta-llama/llama-3.3-70b-instruct:free

# استرجاع معرفة خفيف (RAG) قبل الـ LLM — عطّل بـ 0 أو false
# KNOWLEDGE_RAG=1
# حد المقتطفات لكل مستخدم ويب ثابت في الكود (200) — غيّره في server/routers/knowledgeRouter.ts إن لزم

# --- دومينك بدل تليجرام (الواجهة = موقع ويب؛ تليجرام اختياري) ---
# عطّل البوت إن لم ترد تليجرام:
# TELEGRAM_BOT_DISABLED=1
# استمع على كل الواجهات (للوصول من الشبكة أو من خلف nginx على نفس الجهاز):
# HOST=0.0.0.0
# PORT=3000
# خلف nginx/caddy (HTTPS) — ليثق بـ X-Forwarded-For لحد المعدل:
# TRUST_PROXY=1
# ضغط gzip للاستجابات في الإنتاج — عطّل بـ 0
# COMPRESSION=1
# للتذكير فقط في السجلات (OAuth يأخذ redirect من المتصفح تلقائياً):
# PUBLIC_APP_URL=https://chat.example.com
# في لوحة OAuth سجّل Redirect URI: https://chat.example.com/api/oauth/callback
# توقيع كوكي الجلسة (إلزامي للتشغيل الفعلي)
# JWT_SECRET=ضع_سلسلة_عشوائية_طويلة_واحدة
# OAuth (Manus / خادمك) — كما في لوحة التحكم
# OAUTH_SERVER_URL=https://...
# OWNER_OPEN_ID=
# معرّف التطبيق في الواجهة (إن طلبه مزوّد OAuth)
# VITE_APP_ID=
# عند فشل OAuth يُعاد التوجيه إلى: /?oauth_error=1 (تعرض الواجهة تنبيهاً)

# --- برنامج على الكمبيوتر الشخصي ---
# 1) نفس المشروع: pnpm install && pnpm run dev ثم افتح http://localhost:3000
# 2) Docker: docker compose up --build ثم نفس الرابط (أو المنفذ الذي ضبطته)
# 3) تطبيق سطح مكتب منفصل (Electron/Tauri): غير مضمّن حالياً؛ يمكن لاحقاً تغليف نفس الواجهة في نافذة

# --- ترحيلات DB (مرحلة عزل + ويب): نفّذ بعد تغيير المخطط ---
# توليد + ترحيل: pnpm db:push
# ترحيل فقط (بعد وجود ملفات SQL): DATABASE_URL=... pnpm db:migrate
# 0003_tenant_isolation.sql … 0006_user_feedback.sql  0007_collective_pattern_stats.sql

# دليل النشر على دومينك: docs/DEPLOY_DOMAIN_AR.md
# مراقبة خفيفة: GET /health أو /api/health — لوحة /status (مسؤول فقط) + system.healthDeep
# أمثلة نسخ MySQL: scripts/backup-mysql.example.sh و .ps1

# --- واجهة منفصلة عن الـ API (نادر) ---
# عنوان tRPC الكامل عند البناء (مثال: https://api.example.com/api/trpc)
# VITE_TRPC_URL=https://api.example.com/api/trpc
# على الخادم: قائمة أصول مسموحة مفصولة بفواصل (نفس أصل الواجهة)
# CORS_ORIGINS=https://app.example.com,http://localhost:5173

# إعداد تجريبي محلي بدون Git — انسخ local.runtime.example.json → local.runtime.json
